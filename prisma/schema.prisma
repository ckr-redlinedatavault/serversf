// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Student {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  enrolled  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]
}

model Program {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  date        DateTime
  location    String
  price       String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tickets     Ticket[]
}

model Ticket {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  ticketHash String   @unique
  createdAt DateTime @default(now())
}

model Review {
  id               String   @id @default(cuid())
  userName         String
  teamName         String
  teamMembers      String[]
  eventReview      String
  juryFeedback     String
  hackathonJourney String
  createdAt        DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(MEDIA_TEAM)
  isApproved Boolean  @default(false)
  tasks      Task[]   @relation("UserTasks")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  internForm InternForm? @relation("InternUserForm")
}

enum Role {
  MEDIA_TEAM
  CTO
  CEO
  INTERN
}

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String
  attachmentUrl   String?  // PDF Link or other resource
  assignedRole    Role     @default(INTERN)
  assignedToId    String?  
  user            User?    @relation("UserTasks", fields: [assignedToId], references: [id])
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Script {
  id          String   @id @default(cuid())
  title       String
  content     String
  submittedBy String
  status      String   @default("pending") // pending, reviewed, approved
  createdAt   DateTime @default(now())
}

model Course {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  instructorName  String
  instructorBio   String?
  instructorExp   String?
  instructorImage String?
  rating          Float    @default(0)
  ratingCount     Int      @default(0)
  enrolledCount   Int      @default(0)
  language        String   @default("English")
  lastUpdated     DateTime @default(now())
  thumbnail       String?
  videoUrl        String?
  price           String?
  level           String   @default("Beginner") // Beginner, Intermediate, Advanced
  
  // Section 2: Overview
  description     String
  outcomes        String[] // Array of strings (What You Will Learn)
  skills          String[] // Skills You'll Gain
  targetAudience  String[] // Who This Course Is For
  
  // Section 3 & 4: Curriculum & Timeline 
  // Structure: [{ moduleTitle: string, lessons: [{ title: string, duration: string, type: string, preview: boolean }] }]
  curriculum      Json?    
  // Structure: { totalDuration: string, weeklyPlan: [{ week: string, topic: string }], studyTimePerWeek: string, scheduleType: string }
  timeline        Json?    
  
  // Section 5: Requirements
  requirements    String[]
  
  // Section 6: Assignments
  projectsCount      Int     @default(0)
  hasRealWorldProjects Boolean @default(true)
  hasCapstone        Boolean @default(false)
  practiceExercises  String?
  
  // Section 7: Certification
  hasCertificate      Boolean @default(true)
  isShareableLinkedIn Boolean @default(true)
  issuerName          String?
  
  // Section 10: What's Included
  totalHours           String?
  lecturesCount        Int     @default(0)
  downloadableResources Int     @default(0)
  access              String  @default("Lifetime")
  
  // Section 11: FAQs
  // Structure: [{ question: string, answer: string }]
  faqs                Json?   

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  enrollments         CourseEnrollment[]
}

model CourseEnrollment {
  id              String   @id @default(cuid())
  course          Course   @relation(fields: [courseId], references: [id])
  courseId        String
  
  // Step 1: Personal Details
  name            String
  phone           String
  email           String
  college         String
  branch          String
  year            String
  whyJoin         String
  
  // Step 2 & 3: Payment Details
  paymentMethod   String   @default("MANUAL_UPI") // RAZORPAY, MANUAL_UPI
  amount          String
  
  // Manual UPI Specific
  referenceId     String?  @unique // UTR / Ref No
  transactionId   String?  // Internal or Manual ID
  bankName        String?
  accountName     String?
  
  // Razorpay Specific
  razorpayOrderId    String?  @unique
  razorpayPaymentId  String?  @unique
  razorpaySignature  String?
  
  status          String   @default("pending") // pending, verified, rejected, captured
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id              String   @id @default(cuid())
  teamName        String
  teamLeader      String
  teamMembers     String[]
  githubRepo      String
  submissionDate  DateTime @default(now())
  status          String   @default("live") // default to live as requested "every submitted project must be shown"
  hackathonName   String   @default("HACK FORGE Hackathon 2026")
}

model InternForm {
  id            String   @id @default(cuid())
  userId        String?  @unique
  user          User?    @relation("InternUserForm", fields: [userId], references: [id])
  name          String
  year          String
  branch        String
  college       String
  phoneNumber   String
  githubLink    String
  portfolioLink String?
  status        String   @default("pending") // pending, active, completed, rejected
  createdAt     DateTime @default(now())
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expires   DateTime
  createdAt DateTime @default(now())
}

model FailedTransaction {
  id              String   @id @default(cuid())
  courseId        String?
  email           String?
  name            String?
  phone           String?
  amount          String?
  paymentMethod   String?
  reason          String?
  errorDetails    Json?
  razorpayOrderId String?   @unique
  razorpayPaymentId String? @unique
  createdAt       DateTime  @default(now())
}

model Idea {
  id          String   @id @default(cuid())
  name        String
  subline     String
  title       String
  description String
  likes       Int      @default(0)
  shares      Int      @default(0)
  createdAt   DateTime @default(now())
}
